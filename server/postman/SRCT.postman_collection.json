        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data.token) { pm.environment.set(\"userToken\", data.token); }",
                  "if (data.user && data.user.id) { pm.environment.set(\"userId\", data.user.id); }"
                ],
                "type": "text/javascript"
              }
            }
